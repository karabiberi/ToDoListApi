using Swashbuckle.AspNetCore.SwaggerGen;

namespace ToDoListApi.Extensions
{
    public static class SwaggerJwtExtensions
    {
        public static void AddBearerTokenSecurity(this SwaggerGenOptions c)
        {
            // Use reflection to add security definition
            var method = c.GetType().GetMethod("AddSecurityDefinition");
            if (method == null) return;

            // Create OpenApiSecurityScheme dynamically
            var securitySchemeType = Type.GetType("Microsoft.OpenApi.Models.OpenApiSecurityScheme,Microsoft.OpenApi");
            if (securitySchemeType == null) return;

            dynamic securityScheme = Activator.CreateInstance(securitySchemeType);
            securityScheme.Type = 1; // Http
            securityScheme.Scheme = "bearer";
            securityScheme.BearerFormat = "JWT";
            securityScheme.Description = "JWT Authorization header using the Bearer scheme.";
            securityScheme.Name = "Authorization";
            securityScheme.In = 0; // Header

            method.Invoke(c, new object[] { "Bearer", securityScheme });

            // Add security requirement
            var requirementType = Type.GetType("Microsoft.OpenApi.Models.OpenApiSecurityRequirement,Microsoft.OpenApi");
            if (requirementType == null) return;

            dynamic securityReq = Activator.CreateInstance(requirementType);
            var secSchemeType = Type.GetType("Microsoft.OpenApi.Models.OpenApiSecurityScheme,Microsoft.OpenApi");
            dynamic secScheme2 = Activator.CreateInstance(secSchemeType);
            var refType = Type.GetType("Microsoft.OpenApi.Models.OpenApiReference,Microsoft.OpenApi");
            dynamic ref2 = Activator.CreateInstance(refType);
            ref2.Type = 5; // SecurityScheme
            ref2.Id = "Bearer";
            secScheme2.Reference = ref2;

            securityReq.Add(secScheme2, new List<string>());

            var addReqMethod = c.GetType().GetMethod("AddSecurityRequirement");
            addReqMethod?.Invoke(c, new object[] { securityReq });
        }
    }
}
